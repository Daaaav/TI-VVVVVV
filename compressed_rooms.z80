endpage(2)

defpage(3)
copy_room_to_RAM_page3:
	; Jumped to, after HL and BC are set to the
	; compressed data for the correct room.
	; Copies the data to RAM and does the final ret back to page 0.

	ld de, roomdata_compressed
	ldir

	ret

get_compressed_room_from_lut_page3:
	; Jumped to, expects A to be relative room X,
	; and IX to be set to the start point of a LUT
	ld b, 0
	ld c, a
	add ix, bc
	add ix, bc

	; IX now has a pointer TO a pointer to the data
	ld h, (ix + 1)
	ld l, (ix)
	; HL now has a pointer to the data (well, the byte count before it...)
	; Make sure HL points to the data itself, and BC contains the byte count
	ld a, (hl)
	ld c, a
	inc hl
	ld a, (hl)
	ld b, a
	inc hl
	jp copy_room_to_RAM_page3

get_compressed_room_bad_page3:
	; Jumped to, if the coordinates are out of range

	ld bc, 3
	ld hl, compressed_room_bad_data_page3
	jr copy_room_to_RAM_page3

compressed_room_bad_data_page3:
	.db $40 ; Place byte 00000000...
	.db $7F ; ...130 times
	.db $FF ; Repeat previous 20 bytes 31 times, totaling 750

get_compressed_room_page3:
	; Called (possibly across pages).
	; End result: the compressed data is in roomdata_compressed.
	ld a, (room_y)
	cp 14
	jp z, get_compressed_room_y14
	cp 15
	jp z, get_compressed_room_y15
	cp 16
	jp z, get_compressed_room_y16
	cp 17
	jp z, get_compressed_room_y17
	cp 18
	jp z, get_compressed_room_y18
	jp get_compressed_room_y19

get_compressed_room_y14:
	ld a, (room_x)
	; X must not be 20 or bigger
	cp 20
	jp nc, get_compressed_room_bad_page3

	ld ix, get_compressed_room_y14_lut
	jp get_compressed_room_from_lut_page3

get_compressed_room_y14_lut:
	.dw compressed_room_y14_x0_data
	.dw compressed_room_y14_x1_data
	.dw compressed_room_y14_x2_data
	.dw compressed_room_y14_x3_data
	.dw compressed_room_y14_x4_data
	.dw compressed_room_y14_x5_data
	.dw compressed_room_y14_x6_data

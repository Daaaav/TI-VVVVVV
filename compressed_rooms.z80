endpage(1)

defpage(2)
copy_room_to_RAM_page2:
	; Jumped to, after HL and BC are set to the
	; compressed data for the correct room.
	; Copies the data to RAM and does the final ret back to page 0.

	ld de, roomdata_compressed
	ldir

	ret

get_compressed_room_from_lut_page2:
	; Jumped to, expects A to be relative room X,
	; and IX to be set to the start point of a LUT
	ld b, 0
	ld c, a
	add ix, bc
	add ix, bc

	; IX now has a pointer TO a pointer to the data
	ld h, (ix + 1)
	ld l, (ix)
	; HL now has a pointer to the data (well, the byte count before it...)
	; Make sure HL points to the data itself, and BC contains the byte count
	ld a, (hl)
	ld c, a
	inc hl
	ld a, (hl)
	ld b, a
	inc hl
	jp copy_room_to_RAM_page2

get_compressed_room_bad_page2:
	; Jumped to, if the coordinates are out of range

	ld bc, 3
	ld hl, compressed_room_bad_data_page2
	jr copy_room_to_RAM_page2

compressed_room_bad_data_page2:
	.db $40 ; Place byte 00000000...
	.db $7F ; ...130 times
	.db $FF ; Repeat previous 20 bytes 31 times, totaling 750

get_compressed_room_page2:
	; Called (possibly across pages).
	; End result: the compressed data is in roomdata_compressed.
	ld a, (room_y)
	cp 9
	jp z, get_compressed_room_y9
	cp 10
	jp z, get_compressed_room_y10
	cp 11
	jp z, get_compressed_room_y11
	cp 12
	jp z, get_compressed_room_y12
	jp get_compressed_room_y13

get_compressed_room_y9:
	ld a, (room_x)
	; X must not be 20 or bigger
	cp 20
	jp nc, get_compressed_room_bad_page2

	ld ix, get_compressed_room_y9_lut
	jp get_compressed_room_from_lut_page2

get_compressed_room_y9_lut:
	.dw compressed_room_y9_x0_data
	.dw compressed_room_y9_x1_data
	.dw compressed_room_y9_x2_data
	.dw compressed_room_y9_x3_data
	.dw compressed_room_y9_x4_data
	.dw compressed_room_y9_x5_data
